# ── Stellar Network ───────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet

# ── Registry Account ──────────────────────────────────────────────────────────
# A dedicated Stellar account that acts as the agent registry.
# Generate one with: stellar-agent wallet create
# Then copy the public + secret key here.
STELLAR_REGISTRY_ADDRESS=
STELLAR_REGISTRY_SECRET=

# ── Pinata IPFS ────────────────────────────────────────────────────────────────
# Get your JWT at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=
PINATA_GATEWAY=gateway.pinata.cloud

# ── Groq ──────────────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=

# ── ngrok ─────────────────────────────────────────────────────────────────────
# Get your token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ── Optional: Web Search ──────────────────────────────────────────────────────
# Pick one — Tavily recommended (https://tavily.com)
# TAVILY_API_KEY=
# BRAVE_API_KEY=
BLOCKBOT_MODE=local